# --- DRP domain error messages (DomainError.code -> message) ---
error.drp.entity.emptyName = Entity name cannot be empty.
error.drp.entity.duplicateName = An entity with this name already exists.
error.drp.entity.notFound = Entity not found.
error.drp.asset.emptyValue = Asset value cannot be empty.
error.drp.asset.invalidType = Invalid asset type (domain or subdomain).
error.drp.asset.duplicate = This asset already exists for this entity.
error.drp.asset.notFound = Asset not found.
error.drp.assetGroup.emptyName = Asset group name cannot be empty.
error.drp.assetGroup.duplicateName = An asset group with this name already exists for this entity.
error.drp.assetGroup.entityMismatch = An asset can only join a group that belongs to the same entity.
error.drp.assetGroup.notFound = Asset group not found.
error.drp.exclusion.emptyValue = Exclusion value cannot be empty.
error.drp.exclusion.invalidMatchType = Invalid match type.
error.drp.exclusion.duplicate = This exclusion already exists for this entity.
error.drp.exclusion.notFound = Exclusion not found.

# =========================================================================
# DRP — Candidate Discovery Intake & Staging (US-363)
# =========================================================================

# --- UI texts ---
drp.discovery.submitted = Discovery submitted successfully.
drp.discovery.notFound = Discovery not found.
drp.permutation.submitted = Permutation intake triggered successfully.
# {0} -> count of newly staged discoveries
drp.permutation.staged = {0} new discoveries staged.

# --- DRP domain error messages (discovery) ---
error.drp.discovery.emptyValue = Discovery value cannot be empty.
error.drp.discovery.assetEntityMismatch = The selected asset does not belong to the selected entity.
error.drp.discovery.assetNotDomainType = Permutation intake is only available for domain-type assets.
error.drp.discovery.assetNotActive = The selected asset is not active.
error.drp.discovery.permutationProviderFailure = The permutation provider encountered an error. Please try again.
error.drp.discovery.notFound = Discovery not found.
