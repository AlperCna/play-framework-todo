drp.entity.edit = Edit Entity
drp.entity.created = Entity created.
drp.entity.updated = Entity updated.
drp.entity.notFound = Entity not found.
drp.asset.new = New Asset
drp.asset.edit = Edit Asset
drp.asset.created = Asset created.
drp.asset.updated = Asset updated.
drp.asset.notFound = Asset not found.
