# =========================================================================
# English translations (alternative language)
# Used when the active language is "en" (e.g. play.i18n.langs starts with "en"
# or the client's Accept-Language header prefers English).
# =========================================================================

# --- Task field labels (the _label values of form helpers) ---
task.title = Title
task.description = Description
task.priority = Priority
task.dueDate = Due date

# --- Priority values (0/1/2) ---
task.priority.0 = Low
task.priority.1 = Medium
task.priority.2 = High

# --- Form / page texts ---
task.form.new = New Task
# {0} -> the id of the related task, substituted via MessageFormat.
task.form.edit = Edit Task #{0}
task.form.save = Save
task.form.cancel = Cancel

# --- Flash info messages ---
task.created = Task created.
task.updated = Task updated.
task.deleted = Task deleted.
task.completed = Task completed.
task.reopened = Task reopened.
task.notFound = Task with id {0} not found.

# --- Validation error messages ---
# nonEmptyText produces the "error.required" key for an empty field.
error.required = This field cannot be empty.
# Produced when the priority dropdown sends an invalid value (form level).
error.invalidPriority = Invalid priority value.

# --- Domain (business rule) error messages: DomainError.code -> message ---
error.domain.emptyTitle = Title cannot be empty.
error.domain.emptyEmail = Email cannot be empty.
error.domain.emptyPassword = Password cannot be empty.
error.domain.emptyCategoryName = Category name cannot be empty.
error.domain.emptyCategoryDescription = Category description cannot be empty.
error.domain.invalidUserId = User id must be greater than zero.
error.domain.invalidTaskItemId = Task id must be greater than zero.
error.domain.invalidCategoryId = Category id must be greater than zero.
error.domain.highPriorityRequiresDueDate = High priority tasks require a due date.
error.domain.taskPastDueCannotComplete = A task past its due date cannot be completed.
error.domain.categoryDeleted = A task cannot be assigned to a deleted category.
error.domain.invalidPriorityValue = Invalid priority value.
error.domain.notFound = The requested record was not found.

