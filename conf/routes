# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Gorev (TaskItem) CRUD
# HTML formlari sadece GET ve POST destekledigi icin guncelleme/silme de POST kullanir.
GET     /tasks                      controllers.TaskItemController.list()
GET     /tasks/new                  controllers.TaskItemController.createForm()
POST    /tasks                      controllers.TaskItemController.create()
GET     /tasks/:id/edit             controllers.TaskItemController.editForm(id: Long)
POST    /tasks/:id                  controllers.TaskItemController.update(id: Long)
POST    /tasks/:id/complete         controllers.TaskItemController.complete(id: Long)
POST    /tasks/:id/reopen           controllers.TaskItemController.reopen(id: Long)
POST    /tasks/:id/delete           controllers.TaskItemController.delete(id: Long)

# ForTry
GET    /fortry/try1                      controllers.ForTryController.try1()
GET    /fortry/try2                      controllers.ForTryController.try2()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
