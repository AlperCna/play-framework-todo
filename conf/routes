# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Kimlik dogrulama (auth) — PUBLIC
GET     /login                      controllers.AuthController.loginForm()
POST    /login                      controllers.AuthController.login()
GET     /register                   controllers.AuthController.registerForm()
POST    /register                   controllers.AuthController.register()
POST    /logout                     controllers.AuthController.logout()

# Gorev (TaskItem) CRUD
# HTML formlari sadece GET ve POST destekledigi icin guncelleme/silme de POST kullanir.
GET     /tasks                      controllers.TaskItemController.list()
GET     /tasks/new                  controllers.TaskItemController.createForm()
POST    /tasks                      controllers.TaskItemController.create()
GET     /tasks/:id/edit             controllers.TaskItemController.editForm(id: Long)
POST    /tasks/:id                  controllers.TaskItemController.update(id: Long)
POST    /tasks/:id/complete         controllers.TaskItemController.complete(id: Long)
POST    /tasks/:id/reopen           controllers.TaskItemController.reopen(id: Long)
POST    /tasks/:id/delete           controllers.TaskItemController.delete(id: Long)
# AJAX (JSON) — listede sayfa yenilenmeden tamamla/yeniden-ac
POST    /tasks/:id/complete.json    controllers.TaskItemController.completeJson(id: Long)
POST    /tasks/:id/reopen.json      controllers.TaskItemController.reopenJson(id: Long)
# Gorev <-> Kategori atama (gorev edit sayfasindan)
POST    /tasks/:id/categories                       controllers.TaskItemController.assignToCategory(id: Long)
POST    /tasks/:id/categories/:categoryId/remove    controllers.TaskItemController.removeFromCategory(id: Long, categoryId: Long)

# Kategori (Category) CRUD
GET     /categories                 controllers.CategoryController.list()
GET     /categories/new             controllers.CategoryController.createForm()
POST    /categories                 controllers.CategoryController.create()
GET     /categories/:id/edit        controllers.CategoryController.editForm(id: Long)
POST    /categories/:id             controllers.CategoryController.update(id: Long)
POST    /categories/:id/delete      controllers.CategoryController.delete(id: Long)

# ForTry
GET    /fortry/try1                      controllers.ForTryController.try1()
GET    /fortry/try2                      controllers.ForTryController.try2()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
