task.category.heading = Kategoriler
task.category.none = Bu goreve henuz kategori atanmamis.
task.category.add = Ekle
task.category.remove = Cikar
task.category.assigned = Gorev kategoriye atandi.
task.category.removed = Gorev kategoriden cikarildi.
task.category.invalid = Gecersiz kategori secimi.

