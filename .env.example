# Mona DRP — Local Environment
# cp .env.example .env  →  kendi değerlerinizi girin

DB_HOST=localhost
DB_PORT=55432
DB_NAME=mona_drp
DB_USER=mona
DB_PASSWORD=mona_drp_secret

# psql bağlantı URL'i (scripts tarafından kullanılır)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
